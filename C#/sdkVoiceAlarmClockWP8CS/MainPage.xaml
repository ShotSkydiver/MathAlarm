<phone:PhoneApplicationPage
    x:Class="MathClock.MainPage"
    x:Name="main"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:phone="clr-namespace:Microsoft.Phone.Controls;assembly=Microsoft.Phone"
    xmlns:shell="clr-namespace:Microsoft.Phone.Shell;assembly=Microsoft.Phone"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:toolkit="clr-namespace:Microsoft.Phone.Controls;assembly=Microsoft.Phone.Controls.Toolkit"
    xmlns:Controls="clr-namespace:Coding4Fun.Toolkit.Controls;assembly=Coding4Fun.Toolkit.Controls"
    xmlns:telerikPrimitives="clr-namespace:Telerik.Windows.Controls;assembly=Telerik.Windows.Controls.Primitives"
    xmlns:telerikInput="clr-namespace:Telerik.Windows.Controls;assembly=Telerik.Windows.Controls.Input"
    xmlns:local="clr-namespace:MathClock"
    mc:Ignorable="d"
    FontFamily="{StaticResource PhoneFontFamilyNormal}"
    FontSize="{StaticResource PhoneFontSizeNormal}"
    Foreground="{StaticResource PhoneForegroundBrush}"
    SupportedOrientations="Portrait" Orientation="Portrait"
    shell:SystemTray.IsVisible="True"
    Style="{StaticResource TransitionPageStyle}">

    <UserControl.Resources>
        <local:BooleanToPictureConverter x:Key="vibrationConverter">
            <local:BooleanToPictureConverter.OnImage>
                <Image Source="Images/vib-on.png" Stretch="None" Width="36" Height="36"/>
            </local:BooleanToPictureConverter.OnImage>
            <local:BooleanToPictureConverter.OffImage>
                <Image Source="Images/vib-off.png" Width="36" Height="36"/>
            </local:BooleanToPictureConverter.OffImage>
        </local:BooleanToPictureConverter>
    </UserControl.Resources>

    <phone:PhoneApplicationPage.ApplicationBar>
        <shell:ApplicationBar IsVisible="True" IsMenuEnabled="True">
            <shell:ApplicationBarIconButton x:Name="alarmButton"
                                            IconUri="/Assets/AppBar/questionmark.png"
                                            Text="about"
                                            Click="SetAlarmButton_Click"/>
            <shell:ApplicationBarIconButton x:Name="settingsButton"
                                            IconUri="/Assets/AppBar/appbar.alarm.png"
                                            Text="Set Alarm"
                                            Click="Settings_OnClick"/>
        </shell:ApplicationBar>
    </phone:PhoneApplicationPage.ApplicationBar>

    <Grid x:Name="Container" Background="Transparent">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="SettingsStateGroup">
                <VisualStateGroup.Transitions>
                    <VisualTransition GeneratedDuration="0:0:0.3">
                        <VisualTransition.GeneratedEasingFunction>
                            <CubicEase EasingMode="EaseInOut"/>
                        </VisualTransition.GeneratedEasingFunction>
                    </VisualTransition>
                </VisualStateGroup.Transitions>
                <VisualState x:Name="SettingsOpenState">
                    <Storyboard>
                        <DoubleAnimation Duration="0" To="300" Storyboard.TargetProperty="(UIElement.Projection).(PlaneProjection.GlobalOffsetX)" 
                                         Storyboard.TargetName="LayoutRoot" d:IsOptimized="True"/>
                        <DoubleAnimation Duration="0" To="480" Storyboard.TargetProperty="(UIElement.Projection).(PlaneProjection.GlobalOffsetX)" 
                                         Storyboard.TargetName="SettingsPane" d:IsOptimized="True"/>
                    </Storyboard>
                </VisualState>
                <VisualState x:Name="SettingsClosedState"/>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
        <Grid x:Name="SettingsPane"
              Margin="-480,0,0,-1"
              Grid.Row="0" Background="#FF2C2C2C">
            <Grid.Projection>
                <PlaneProjection/>
            </Grid.Projection>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="SET ALARM" Margin="14,3,671,292" Style="{StaticResource PhoneTextTitle1Style}" 
        		Foreground="#FFE6E6E6" FontFamily="Segoe WP Semibold" FontSize="52"/>
            <toolkit:Separator HorizontalAlignment="Left" Height="100" Margin="15,38,0,0" 
                               VerticalAlignment="Top" Width="278" Grid.RowSpan="2" Background="#FFF5F5E7" BorderThickness="0"/>

            <toolkit:ToggleSwitch Content="Alarm"
                                           x:Name="notificationSwitch"
                                           Margin="20,92,671,0" Unchecked="notificationSwitch_Unchecked" 
                                           Checked="notificationSwitch_Checked"/>

            <StackPanel x:Name="settingsPanel" Grid.Row="0" Margin="12,169,0,196" Height="0">
                <toolkit:TimePicker x:Name="timePicker" HorizontalAlignment="Left" VerticalAlignment="Top" 
            		ValueChanged="timePicker_ValueChanged" Header="alarm time" Width="296" 
            		BorderThickness="1" Margin="-6,0,0,0"/>
            	<!--
            					<TextBlock Text="{Binding Caption}" FontSize="36"/>
            				</StackPanel>
            			</DataTemplate>
            		</toolkit:ListPicker.FullModeItemTemplate>
            	</toolkit:ListPicker>-->
            	<ToggleButton x:Name="vibrationToggleSwitch" 
            		Content="{Binding IsChecked, Converter={StaticResource vibrationConverter}, RelativeSource={RelativeSource Self}}" 
            		HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="19.333" 
            		Foreground="DarkGray" BorderThickness="1" FontFamily="Segoe WP" Checked="vibrationToggleSwitch_Checked"
            		Unchecked="vibrationToggleSwitch_Unchecked" Margin="-7,0,0,0"/>
                <TextBlock TextWrapping="Wrap" Margin="5,0,664,0" Text="You need to lock your device with this app running in the foreground in order for it to work properly!" FontSize="16" Foreground="#FFBBBBBB"/>
                    
            	<toolkit:Separator HorizontalAlignment="Left" Height="100" Margin="1,0,0,0" 
            		VerticalAlignment="Top" Width="278" Background="#FFF5F5E7" BorderThickness="0"/>
            </StackPanel>

            <!--<Rectangle x:Name="minute" Fill="#FFF4F4F5" HorizontalAlignment="Left" Height="12" Margin="129,410,0,0" Stroke="Black" VerticalAlignment="Top" Width="133" RenderTransformOrigin="0.078,0.479" Grid.Row="1" Opacity="0.31">
            	<Rectangle.RenderTransform>
            		<CompositeTransform Rotation="0"/>
            	</Rectangle.RenderTransform>
            </Rectangle>
            <Rectangle x:Name="hour" Fill="#FFF4F4F5" HorizontalAlignment="Left" Height="47" Margin="149,422,0,0" Stroke="Black" VerticalAlignment="Top" Width="8" RenderTransformOrigin="0.097,0.5" Grid.Row="1" Opacity="0.31">
            	<Rectangle.RenderTransform>
            		<CompositeTransform ScaleX="1.5" ScaleY="1.5" TranslateX="-20.15"/>
            	</Rectangle.RenderTransform>
            </Rectangle>
            <Rectangle x:Name="second" Fill="#FFC9C9C9" HorizontalAlignment="Left" Height="5.328" Margin="92.356,451.628,0,0" Stroke="Black" VerticalAlignment="Top" Width="169.051" RenderTransformOrigin="0.246,0.492" Grid.Row="1" UseLayoutRounding="False" d:LayoutRounding="Auto" Opacity="0.31">
            	<Rectangle.RenderTransform>
            		<CompositeTransform Rotation="90" TranslateX="-2.588" TranslateY="-2.592"/>
            	</Rectangle.RenderTransform>
            </Rectangle>-->

        </Grid>

        <!--LayoutRoot is the root grid where all page content is placed-->
        <Grid x:Name="LayoutRoot" Background="Black">
            <!--<MediaElement x:Name="mediaElement"></MediaElement>-->
            <Grid.Projection>
                <PlaneProjection/>
            </Grid.Projection>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
        	<StackPanel x:Name="TitlePanel" Grid.Row="0" Margin="12,17,0,28" Grid.RowSpan="2">
        		<toolkit:Separator HorizontalAlignment="Left" Height="100" Margin="10,-50,0,0" VerticalAlignment="Top" Width="436" Background="#FF898989"/>
        		<!--<TextBlock x:Name="title" Text="math clock" Margin="9,-7,0,0" Style="{StaticResource PhoneTextTitle1Style}" d:IsHidden="True"/>-->
        	</StackPanel>

        	<Grid x:Name="ContentPanel" Grid.Row="1" Margin="14,177,10,-177">
        		<TextBlock x:Name="itIs" HorizontalAlignment="Left" Margin="390,-163,0,0" TextWrapping="Wrap" Text="it is" VerticalAlignment="Top" FontSize="38.667" FontFamily="Segoe WP Light"/>
        		<TextBlock x:Name="monTextBlock" HorizontalAlignment="Left" Margin="276,-90,0,0" TextWrapping="Wrap" Text="MONDAY" VerticalAlignment="Top" FontSize="38.667" FontFamily="Segoe WP Semibold"/>
        		<TextBlock x:Name="tueTextBlock" HorizontalAlignment="Left" Margin="280,-49,0,0" TextWrapping="Wrap" Text="TUESDAY" VerticalAlignment="Top" FontFamily="Segoe WP Semibold" FontSize="38.667"/>
        		<TextBlock x:Name="wedTextBlock" HorizontalAlignment="Left" Margin="215,-9,0,0" TextWrapping="Wrap" Text="WEDNESDAY" VerticalAlignment="Top" FontSize="38.667" FontFamily="Segoe WP Semibold"/>
        		<TextBlock x:Name="thuTextBlock" HorizontalAlignment="Left" Margin="249,33,0,0" TextWrapping="Wrap" Text="THURSDAY" VerticalAlignment="Top" FontFamily="Segoe WP Semibold" FontSize="38.667"/>
        		<TextBlock x:Name="friTextBlock" HorizontalAlignment="Left" Margin="315,74,0,0" TextWrapping="Wrap" Text="FRIDAY" VerticalAlignment="Top" FontFamily="Segoe WP Semibold" FontSize="38.667"/>
        		<TextBlock x:Name="satTextBlock" HorizontalAlignment="Left" Margin="253,113,0,0" TextWrapping="Wrap" Text="SATURDAY" VerticalAlignment="Top" FontFamily="Segoe WP Semibold" FontSize="38.667"/>
        		<TextBlock x:Name="sunTextBlock" HorizontalAlignment="Left" Margin="292,-128,0,0" TextWrapping="Wrap" VerticalAlignment="Top" FontSize="38.667" FontFamily="Segoe WP Semibold" Text="SUNDAY"/>
        		<TextBlock x:Name="hourText" HorizontalAlignment="Left" Margin="2,-210,0,0" TextWrapping="Wrap" Text="01:" VerticalAlignment="Top" FontSize="178.667" FontFamily="Segoe WP Light" FontWeight="ExtraLight" Foreground="#FFE0E0E0"/>
        		<TextBlock x:Name="minuteText" HorizontalAlignment="Left" Margin="2,-59,0,0" TextWrapping="Wrap" Text="01" VerticalAlignment="Top" FontSize="178.667" FontFamily="Segoe WP Light" FontWeight="ExtraLight" Foreground="#FFE0E0E0"/>
        		<TextBlock x:Name="secondsText" HorizontalAlignment="Left" Margin="2,91,0,0" TextWrapping="Wrap" Text="01" VerticalAlignment="Top" FontSize="178.667" FontFamily="Segoe WP Light" FontWeight="ExtraLight" Foreground="#FFE0E0E0"/>
        		<TextBlock x:Name="amPM" HorizontalAlignment="Left" Margin="2,249,0,0" TextWrapping="Wrap" Text="PM" VerticalAlignment="Top" FontSize="152" FontFamily="Segoe WP Light" FontWeight="ExtraLight" Foreground="#FFE0E0E0" FontStretch="Condensed"/>
        		<TextBlock x:Name="dateNumber" HorizontalAlignment="Left" Margin="401,410,0,0" TextWrapping="Wrap" Text="22" VerticalAlignment="Top" FontFamily="Segoe WP SemiLight" FontSize="38.667"/>
        		<TextBlock x:Name="month" HorizontalAlignment="Right" Margin="0,375,15,0" TextWrapping="Wrap" Text="SEPTEMBER" VerticalAlignment="Top" FontFamily="Segoe WP Semibold" FontSize="38.667"/>
        		<TextBlock x:Name="alarmTimeText" HorizontalAlignment="Left" Margin="57,466,0,0" TextWrapping="Wrap" Text="4:30 PM" VerticalAlignment="Top" FontFamily="Segoe WP Semibold" FontSize="38.667"/>
        		<Image Margin="-10,408,390,117" Source="/Assets/AppBar/feature.alarm.png" Stretch="None"/>
        		<toolkit:Separator HorizontalAlignment="Left" Height="100" Margin="10,412,0,0" VerticalAlignment="Top" Width="436" Background="#FF898989"/>
        		<!--<TextBlock x:Name="getDifficultyText" HorizontalAlignment="Left" Margin="187,433,0,0" TextWrapping="Wrap" Text="difficulty" VerticalAlignment="Top" Width="247"/>
        		<TextBlock x:Name="getAlarmToneText" HorizontalAlignment="Left" Margin="221,455,0,0" TextWrapping="Wrap" Text="tone" VerticalAlignment="Top" Width="213"/>-->
        	</Grid>
            <TextBlock x:Name="themeCheck" HorizontalAlignment="Left" Margin="293,452,0,0" Grid.Row="1" TextWrapping="Wrap" Text="theme" VerticalAlignment="Top"/>
        </Grid>



        <!--TitlePanel contains the name of the application and page title-->
        <!--<Image x:Name="hourHand" HorizontalAlignment="Left" Height="20" Margin="248,175,0,0" Grid.Row="1" VerticalAlignment="Top" Width="99" Source="/Images/hourHand.jpg" RenderTransformOrigin="0.097,0.5">
                <Image.RenderTransform>
                    <CompositeTransform ScaleX="1.5" ScaleY="1.5" TranslateX="-20.15"/>
                </Image.RenderTransform>
            </Image>
            <Image x:Name="minuteHand" HorizontalAlignment="Left" Height="24" Margin="225,173,0,0" Grid.Row="1" VerticalAlignment="Top" Width="163.333" Source="/Images/minuteHand.png" RenderTransformOrigin="0.078,0.479">
                <Image.RenderTransform>
                    <CompositeTransform Rotation="0"/>
                </Image.RenderTransform>
            </Image>
                <Image x:Name="secondHand" HorizontalAlignment="Left" Height="17.5" Margin="185.349,179.275,0,0" Grid.Row="1" VerticalAlignment="Top" Width="226" Source="/Images/secondHand.png" RenderTransformOrigin="0.246,0.492" UseLayoutRounding="False" d:LayoutRounding="Auto">
                    <Image.RenderTransform>
                        <CompositeTransform Rotation="90" TranslateX="-2.588" TranslateY="-2.592"/>
                    </Image.RenderTransform>
                </Image>-->



        <!--TitlePanel contains the name of the application and page title-->

        <!--ContentPanel - place additional content here-->
    </Grid>
</phone:PhoneApplicationPage>
